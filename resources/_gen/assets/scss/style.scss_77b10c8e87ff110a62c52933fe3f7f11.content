color-mix(in srgb,var(--bubble-color,#8b7dd8) 10%,transparent),0 0 24px color-mix(in srgb,var(--bubble-color,#8b7dd8) 6%,transparent);animation:danmakuFly linear forwards}.danmaku-bubble strong{font-weight:700;margin-right:4px}[data-scheme=dark] .danmaku-bubble{background:color-mix(in srgb,var(--bubble-color,#60b0f4) 8%,transparent);border-color:color-mix(in srgb,var(--bubble-color,#60b0f4) 12%,transparent)}.bf-color{width:28px;height:28px;padding:0;border:1.5px solid var(--card-separator-color);border-radius:50%;cursor:pointer;background:0 0;overflow:hidden;flex-shrink:0}.bf-color::-webkit-color-swatch-wrapper{padding:2px}.bf-color::-webkit-color-swatch{border:none;border-radius:50%}.bf-color::-moz-color-swatch{border:none;border-radius:50%}@keyframes danmakuFly{0%{transform:translateX(0);opacity:0}2%{opacity:1}90%{opacity:1}100%{transform:translateX(calc(-100vw + 200px));opacity:0}}.board-form{display:flex;gap:8px;align-items:center}.bf-name{width:80px;flex-shrink:0;padding:6px 10px;border:1.5px solid var(--card-separator-color);border-radius:8px;background:rgba(255,255,255,4%);color:var(--card-text-color-main);font-size:1.25rem;outline:none;font-family:inherit;transition:border-color .2s}.bf-text{flex:1;padding:6px 10px;border:1.5px solid var(--card-separator-color);border-radius:8px;background:rgba(255,255,255,4%);color:var(--card-text-color-main);font-size:1.25rem;outline:none;font-family:inherit;transition:border-color .2s}.bf-name:focus,.bf-text:focus{border-color:var(--accent-color)}.bf-submit{padding:6px 20px;border:none;border-radius:8px;background:var(--accent-color);color:var(--accent-color-text);cursor:pointer;font-size:1.3rem;font-family:inherit;flex-shrink:0;transition:opacity .2s;line-height:1.4}.bf-submit:hover{opacity:.85}@media(max-width:768px){.board-form{flex-wrap:wrap}.danmaku-stage{height:90px}.danmaku-bubble{font-size:1.15rem;padding:2px 10px}}